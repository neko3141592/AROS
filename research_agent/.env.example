# LLM provider
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o-mini

# LLM API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional observability
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=research-agent-local

# External services
RUNPOD_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# Runtime
LOG_LEVEL=INFO
