# LLM provider
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o-mini
PLANNER_MODEL_NAME=gpt-4o-mini
RESEARCHER_MODEL_NAME=gpt-4o-mini
CODER_MODEL_NAME=gpt-4o-mini
EVALUATOR_MODEL_NAME=gpt-4o-mini
ENABLE_EVALUATOR_LLM_ANALYSIS=1

# LLM API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional observability
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=research-agent-local

# External services
RUNPOD_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# Runtime
LOG_LEVEL=INFO
